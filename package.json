{
  "name": "@w6w/ui",
  "version": "0.0.1",
  "description": "React components for w6w — a workflow platform. Usable in the reference studio or any partner app.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/w6w-io/w6w-ui.git"
  },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./flow": {
      "types": "./src/flow.ts",
      "import": "./src/flow.ts"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lint": "^6.8.4",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.0",
    "@uiw/react-codemirror": "^4.23.7",
    "@xyflow/react": "^12.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.3.0"
  }
}
